SHERPA_SENSEVOICE_LANGUAGE=zh
SHERPA_SENSEVOICE_USE_ITN=true

LEMONADE_BASE_URL=http://127.0.0.1:13305/api/v1
LEMONADE_API_KEY=nopass
LEMONADE_STT_MODEL=Whisper-Large-v3-Turbo
LEMONADE_STT_LANGUAGE=zh
