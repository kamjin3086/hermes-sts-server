# Server
HERMES_STS_HOST=127.0.0.1
HERMES_STS_PORT=8765
HERMES_STS_LOG_LEVEL=INFO
HERMES_STS_SAMPLE_RATE=16000

# Hermes Agent / OpenAI-compatible chat endpoint
HERMES_BASE_URL=http://127.0.0.1:8642/v1
HERMES_MODEL=hermes-agent
HERMES_API_KEY=
HERMES_MAX_TOKENS=120
HERMES_AGENT_MAX_WAIT_SECONDS=60
HERMES_FIRST_FILLER_DELAY_SECONDS=1.2
HERMES_FILLER_INTERVAL_SECONDS=8
HERMES_MAX_FILLERS=2
HERMES_FALLBACK_TEXT=我这边还没有等到完整结果，不过本地语音链路正常。你可以再问一次，我会继续接。
HERMES_FALLBACK_TEXTS=我这边还没有等到完整结果，不过本地语音链路正常。你可以再问一次，我会继续接。|这次后端响应有点慢，我先不断开。你再说一遍或者稍等一下都可以。|我还在等处理结果，当前听和说都正常，我们可以继续。
HERMES_HISTORY_MAX_MESSAGES=40
HERMES_HISTORY_MAX_CHARS=12000
HERMES_HISTORY_IDLE_RESET_SECONDS=900

# Providers: same recommended stack on Windows and Fedora/Linux
STS_LLM_PROVIDER=hermes_agent
STS_LLM_MAX_CONCURRENT_REQUESTS=1
STS_VAD_PROVIDER=sherpa_silero
STS_STT_PROVIDER=sherpa_sensevoice
STS_TTS_PROVIDER=sherpa_kokoro

# Local model paths are resolved relative to the project root
SHERPA_SILERO_VAD_MODEL=./models/silero_vad.onnx
SHERPA_SENSEVOICE_MODEL=./models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-2024-07-17/model.int8.onnx
SHERPA_SENSEVOICE_TOKENS=./models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-2024-07-17/tokens.txt
SHERPA_SENSEVOICE_LANGUAGE=zh
SHERPA_SENSEVOICE_USE_ITN=true
SHERPA_KOKORO_MODEL=./models/kokoro-multi-lang-v1_0/model.onnx
SHERPA_KOKORO_VOICES=./models/kokoro-multi-lang-v1_0/voices.bin
SHERPA_KOKORO_TOKENS=./models/kokoro-multi-lang-v1_0/tokens.txt
SHERPA_KOKORO_LEXICON=./models/kokoro-multi-lang-v1_0/lexicon-us-en.txt,./models/kokoro-multi-lang-v1_0/lexicon-zh.txt
SHERPA_KOKORO_DATA_DIR=./models/kokoro-multi-lang-v1_0/espeak-ng-data
SHERPA_KOKORO_VOICE=47

# Turn-taking, latency, and TTS behavior
VAD_THRESHOLD=0.35
VAD_MIN_SILENCE_SECONDS=0.45
VAD_ENERGY_THRESHOLD=0.004
VAD_START_MS=120
VAD_END_MS=600
VAD_MIN_UTTERANCE_MS=300
VAD_MAX_UTTERANCE_MS=12000
STS_SUPPRESS_INPUT_WHILE_SPEAKING=true
STS_RESPONSE_AUDIO_CHUNK_MS=80
STS_TTS_SEGMENT_MIN_CHARS=24
STS_TTS_SEGMENT_MAX_CHARS=90
STS_TTS_STRIP_BRACKETED_CUES=true
STS_LATENCY_LOGGING=true

# Paths
MODELS_DIR=./models
LOG_DIR=./logs
PYPI_INDEX_URL=https://mirrors.aliyun.com/pypi/simple

# Smoke-test fallback without local models:
# STS_VAD_PROVIDER=energy
# STS_STT_PROVIDER=dev
# STS_TTS_PROVIDER=tone
# HERMES_STS_DEV_TRANSCRIPT=请用一句中文说，STS测试正常吗？
