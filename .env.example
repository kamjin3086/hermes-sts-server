HERMES_STS_HOST=127.0.0.1
HERMES_STS_PORT=8765
HERMES_STS_LOG_LEVEL=INFO
HERMES_STS_SAMPLE_RATE=16000

HERMES_BASE_URL=http://127.0.0.1:8642/v1
HERMES_MODEL=hermes-agent
HERMES_API_KEY=
HERMES_MAX_TOKENS=120
HERMES_TIMEOUT_SECONDS=180
HERMES_CONNECT_TIMEOUT_SECONDS=3
HERMES_READ_TIMEOUT_SECONDS=180
HERMES_AGENT_MAX_WAIT_SECONDS=60
HERMES_FIRST_FILLER_DELAY_SECONDS=1.2
HERMES_FILLER_INTERVAL_SECONDS=8
HERMES_MAX_FILLERS=2
HERMES_ALLOW_FALLBACK=true
HERMES_FALLBACK_TEXT=我这边还没有等到完整结果，不过本地语音链路正常。你可以再问一次，我会继续接。
HERMES_FALLBACK_TEXTS=我这边还没有等到完整结果，不过本地语音链路正常。你可以再问一次，我会继续接。|这次后端响应有点慢，我先不断开。你再说一遍或者稍等一下都可以。|我还在等处理结果，当前听和说都正常，我们可以继续。
HERMES_HISTORY_MAX_MESSAGES=40
HERMES_HISTORY_MAX_CHARS=12000

LLM_FALLBACK_ENABLED=false
LLM_FALLBACK_BASE_URL=http://127.0.0.1:13305/api/v1
LLM_FALLBACK_MODEL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_TIMEOUT_SECONDS=120
LLM_FALLBACK_MAX_TOKENS=120

STS_STT_PROVIDER=sherpa_sensevoice
HERMES_STS_DEV_TRANSCRIPT=请用一句中文说，STS测试正常吗？
